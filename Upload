<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Documents - Invar Chrysos</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <nav class="bg-white shadow sticky top-0 z-50"> <!-- Same nav as apply.html --></nav>

  <div class="max-w-2xl mx-auto mt-12 bg-white rounded-3xl shadow-2xl p-10">
    <h1 class="text-4xl font-bold text-center mb-8">Identity Verification</h1>
    
    <div class="space-y-10">
      <div>
        <label class="block font-medium mb-3">Upload Omang/ID (Front & Back)</label>
        <input type="file" multiple accept="image/*,.pdf" class="w-full border-2 border-dashed border-gray-300 rounded-2xl p-8 text-center">
      </div>
      
      <div>
        <label class="block font-medium mb-3">Take Selfie</label>
        <video id="video" class="w-full rounded-2xl border" autoplay playsinline></video>
        <button onclick="capturePhoto()" class="mt-4 w-full bg-amber-600 text-white py-4 rounded-2xl font-semibold">Capture Selfie Now</button>
        <canvas id="canvas" class="hidden"></canvas>
        <img id="photo" class="mt-6 hidden rounded-2xl mx-auto">
      </div>
    </div>

    <button onclick="window.location.href='agreement.html'" class="mt-12 w-full bg-amber-600 hover:bg-amber-700 text-white py-5 rounded-2xl text-xl font-semibold">
      Continue to Loan Agreement →
    </button>
  </div>

  <script>
    navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } }).then(stream => {
      document.getElementById("video").srcObject = stream;
    });
    function capturePhoto() {
      const video = document.getElementById("video");
      const canvas = document.getElementById("canvas");
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      canvas.getContext("2d").drawImage(video, 0, 0);
      document.getElementById("photo").src = canvas.toDataURL("image/jpeg");
      document.getElementById("photo").classList.remove("hidden");
    }
  </script>
</body>
</html>
